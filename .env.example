# StackAdapt
STACKADAPT_API_KEY=

# Nexd
NEXD_API_KEY=

# Google DV360
DV360_SERVICE_ACCOUNT_JSON_BASE64=
DV360_PARTNER_ID=
DV360_ADVERTISER_IDS=123456,789012

# Xandr
XANDR_USERNAME=
XANDR_PASSWORD=
XANDR_ADVERTISER_IDS=123456,789012

# Amazon DSP
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_DSP_ADVERTISER_IDS=123456,789012
AMAZON_DSP_REGION=NA

# Backend / Frontend
FRONTEND_ORIGIN=http://localhost:3000

# BigQuery snapshot store
BQ_PROJECT_ID=
GCP_CREDS_JSON_CREDS_BASE64=
BQ_DATASET_ID=cost_dashboard_rt
BQ_LOCATION=US
HIVESTACK_BQ_TABLE=site-hypr.staging.hivestack_mediacost

# Share de investimento (0–100) no rateio SA+DV360+Xandr. Deixe vazio para usar 30 / 50 / 13.
DASHBOARD_SHARE_STACKADAPT_PCT=
DASHBOARD_SHARE_DV360_PCT=
DASHBOARD_SHARE_XANDR_PCT=

# Discord (alertas quando refresh falha ou integração retorna erro)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_ALERT_COOLDOWN_SECONDS=600
# DISCORD_NOTIFY_PARTIAL_FAILURES=true

# Dashboard workers / refresh
DASHBOARD_CACHE_TTL_SECONDS=300
DASHBOARD_INTEGRATION_TIMEOUT_SECONDS=45
DASHBOARD_DV360_TIMEOUT_SECONDS=240
DV360_REPORT_POLL_TIMEOUT_SECONDS=240
DASHBOARD_XANDR_TIMEOUT_SECONDS=150
XANDR_REPORT_POLL_TIMEOUT_SECONDS=90
DASHBOARD_FAST_WORKER_INTERVAL_SECONDS=600
DASHBOARD_DV360_WORKER_INTERVAL_SECONDS=1800
POSTGRESS_DATABASE_URL=postgresql://postgres:s%60%3B%605%5C3UElbtC.-5@127.0.0.1:5432/hypr?sslmode=disable&gssencmode=disable
# Troque se as tabelas não estiverem em public.
POSTGRESS_DATABASE_PG_SCHEMA=public
# Opcional: nomes das tabelas usadas para observações e resolução manual/histórica de tokens.
LINE_NO_TOKEN_OBSERVATIONS_TABLE=line_no_token_observations
LINE_TOKEN_RESOLUTIONS_TABLE=line_token_resolutions

# Anthropic Admin API (Claude usage ingestion)
# Sem ANTHROPIC_ADMIN_API_KEY o pipeline desabilita gracefully (endpoints retornam 503).
ANTHROPIC_ADMIN_API_KEY=
CLAUDE_INGESTION_LOOKBACK_DAYS=7
CLAUDE_CACHE_TTL_SECONDS=3600
CLAUDE_INGESTION_TIMEOUT_SECONDS=300
CLAUDE_HTTP_TIMEOUT_SECONDS=30
CLAUDE_SCHEDULER_HOUR_UTC=6
# Token opcional pra proteger /api/claude/refresh e /api/claude/backfill (Authorization: Bearer ...).
# CLAUDE_ADMIN_TOKEN=

# USD->BRL: ptax (Banco Central) ou fixed (USD_BRL_RATE_FIXED)
USD_BRL_RATE_SOURCE=ptax
USD_BRL_RATE_FIXED=4.92

# BigQuery cost dashboard (INFORMATION_SCHEMA.JOBS_BY_PROJECT)
# Regiões separadas por vírgula (sem o prefixo `region-`).
BQ_COST_REGIONS=us,southamerica-east1
BQ_ON_DEMAND_USD_PER_TIB=6.25
BQ_COST_CACHE_TTL_SECONDS=1800
BQ_COST_MAX_RANGE_DAYS=92

# GCP Billing dashboard (standard billing export do GCP em BigQuery)
# FQN da tabela de export: projeto.dataset.gcp_billing_export_v1_<billing_account>
GCP_BILLING_TABLE=
GCP_BILLING_CACHE_TTL_SECONDS=1800
GCP_BILLING_MAX_RANGE_DAYS=92
